# Edison — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edison?schema=public"

# --- Anthropic (Claude API conversation engine) ---
ANTHROPIC_API_KEY=

# --- Twilio (Programmable SMS + Voice webhooks) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Stripe (subscriptions + metered overage) — Day 2 ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Calendar (OAuth2) — Day 2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth ---
NEXTAUTH_SECRET=

# --- App ---
# Public base URL of this app, used when registering Twilio webhooks.
APP_BASE_URL="http://localhost:3000"
# Set to "true" only in local dev to skip Twilio webhook signature validation.
TWILIO_SKIP_SIGNATURE_VALIDATION="false"
