# Edison — environment variables
# Copy to .env and fill in real values. NEVER commit .env (it's gitignored).
# Use .env (not .env.local): the Next.js app AND the Prisma CLI (db:migrate,
# db:seed) both read .env, whereas Prisma ignores .env.local.

# --- Database (PostgreSQL) ---
# On Neon/Vercel: DATABASE_URL = the POOLED string (host has "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/edison?schema=public"
# DIRECT_URL = the DIRECT (unpooled) string, used for migrations.
# If you only have one URL (e.g. local Docker), set it the same as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/edison?schema=public"

# --- Anthropic (Claude API conversation engine) ---
ANTHROPIC_API_KEY=
# SMS triage defaults to the cheapest tier. Override the model without code changes.
CLAUDE_MODEL_ID=claude-haiku-4-5

# --- Twilio (Programmable SMS + Voice webhooks) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Skip Twilio webhook signature validation (local dev only).
TWILIO_SKIP_SIGNATURE_VALIDATION=false

# --- Stripe (subscriptions + metered overage) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: pre-created recurring Price IDs (else checkout uses inline price_data).
STRIPE_PRICE_FOUNDING=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_HIGH_VOLUME=
# Optional: metered Price ID used to push per-conversation overage.
STRIPE_PRICE_OVERAGE=

# --- Google Calendar (OAuth2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) — weekly report, password reset, contact form ---
RESEND_API_KEY=
EMAIL_FROM="Edison <reports@edison.io>"
# Where the marketing contact form is delivered (defaults to EMAIL_FROM).
CONTACT_EMAIL=

# --- Auth ---
NEXTAUTH_SECRET=
# CEO/admin cockpit password (gates /admin).
ADMIN_PASSWORD=
# Shared secret to authorize cron endpoints.
CRON_SECRET=

# --- Maps (Mapbox GL) — multi-location fleet map ---
# Public token (starts with pk.). Optional: without it the map shows a fallback.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- App ---
APP_BASE_URL="http://localhost:3000"
