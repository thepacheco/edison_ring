// Edison — Missed Call Rescue
// Prisma schema. Core models per the build spec (Day 1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (app queries)
  directUrl = env("DIRECT_URL") // direct (migrations); falls back to DATABASE_URL if unset
}

model Business {
  id                String   @id @default(cuid())
  name              String
  ownerEmail        String   @unique // primary contact / billing email
  phoneNumber       String // their forwarded business line
  twilioNumber      String   @unique // the Edison-provisioned number
  carrier           String?
  businessType      String   @default("home_services") // hvac | plumbing | electrical | salon | auto | ...
  setupCompleted    Boolean  @default(false)
  avgTicketPrice    Decimal  @default(0) @db.Decimal(10, 2)
  businessHours     Json? // { mon: {open, close}, ... }
  aiToneSettings    Json? // custom prompt tweaks + greeting override
  routingMode       String   @default("always_to_owner") // always_to_owner | round_robin | keyword
  plan              String   @default("founding") // founding | standard | high_volume
  conversationLimit Int      @default(300)

  // Billing (Stripe)
  stripeCustomerId   String?
  stripeSubId        String?
  subscriptionStatus String    @default("none") // none | trialing | active | past_due | canceled
  trialEndsAt        DateTime?
  canceledAt         DateTime?
  cancelReason       String?
  foundingLockedAt   DateTime? // founding price locked-for-life timestamp
  flaggedForReview   Boolean   @default(false) // hard-cap breach → manual review

  // Calendar (Google)
  googleRefreshToken String?
  googleCalendarId   String? @default("primary")

  createdAt DateTime @default(now())

  locations     Location[]
  conversations Conversation[]
  workers       Worker[]
  usageRecords  UsageRecord[]
  users         User[]
  optOuts       OptOut[]
}

model OptOut {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone      String // customer phone that texted STOP
  createdAt  DateTime @default(now())

  @@unique([businessId, phone])
  @@index([businessId])
}

model User {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("staff") // owner | staff
  isTest       Boolean  @default(false) // demo/dummy user for onboarding tests
  createdAt    DateTime @default(now())

  resetTokens PasswordResetToken[]

  @@index([businessId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 of the emailed token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Location {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  phoneNumber  String   @default("")
  twilioNumber String   @unique
  isPrimary    Boolean  @default(false)
  address      String?
  latitude     Float?
  longitude    Float?
  active        Boolean  @default(true)
  createdAt    DateTime @default(now())

  conversations Conversation[]
}

model Worker {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String
  phoneNumber    String
  isAvailable    Boolean  @default(true) // false when "out"
  backupWorkerId String?
  keywords       String[] // for keyword-based routing
  routingOrder   Int? // for round robin

  conversations Conversation[]
}

model Conversation {
  id               String    @id @default(cuid())
  businessId       String
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationId       String?
  location         Location? @relation(fields: [locationId], references: [id])
  customerPhone    String
  customerName     String?
  status           String    @default("new") // new | booked | needs_followup | closed
  intent           String? // booking_request | urgent | needs_human | general_inquiry
  summary          String? // one-line "what the customer needs"
  estimatedValue   Decimal?  @db.Decimal(10, 2)
  assignedWorkerId String?
  assignedWorker   Worker?   @relation(fields: [assignedWorkerId], references: [id])
  bookedSlot       DateTime?
  exchangeCount    Int       @default(0) // number of customer<->AI back-and-forths
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages Message[]

  @@index([businessId, status])
  @@index([businessId, customerPhone])
  @@index([locationId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      String // inbound | outbound
  body           String
  twilioSid      String? // Twilio message SID for delivery tracking
  inputTokens    Int? // AI-generated outbound: tokens in, for real COGS
  outputTokens   Int? // AI-generated outbound: tokens out
  modelUsed      String? // e.g. "claude-haiku-4-5"
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model UsageRecord {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  month             String // "2026-06"
  conversationCount Int      @default(0)
  overageCount      Int      @default(0)

  @@unique([businessId, month])
}
